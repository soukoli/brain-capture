# Database Configuration
# Priority order: POSTGRES_URL > PG* variables > test_* prefixed variables

# Option 1: Connection String (highest priority)
# For AWS RDS PostgreSQL (recommended):
# POSTGRES_URL="postgresql://username:password@host:port/database?sslmode=require"
POSTGRES_URL="postgresql://postgres:YOUR_PASSWORD@my-brain-capture.cluster-xxxxx.us-east-1.rds.amazonaws.com:5432/postgres?sslmode=require"

# Option 2: Individual PostgreSQL Connection Details
# Supports both standard and test_ prefixed variables
# Standard variables:
PGDATABASE="postgres"
PGHOST="your-host.rds.amazonaws.com"
PGPORT="5432"
PGSSLMODE="require"
PGUSER="postgres"
PGPASSWORD="your-password"

# OR test_ prefixed variables (automatically detected):
# test_PGDATABASE="postgres"
# test_PGHOST="your-host.rds.amazonaws.com"
# test_PGPORT="5432"
# test_PGSSLMODE="require"
# test_PGUSER="postgres"

# AWS RDS Configuration (for Vercel deployment with IAM auth)
# Supports both standard and test_ prefixed variables
AWS_ACCOUNT_ID="your-account-id"
AWS_REGION="us-east-1"
AWS_RESOURCE_ARN="arn:aws:rds:us-east-1:account:cluster:cluster-name"
AWS_ROLE_ARN="arn:aws:iam::account:role/role-name"

# OR test_ prefixed:
# test_AWS_ACCOUNT_ID="your-account-id"
# test_AWS_REGION="us-east-1"
# test_AWS_RESOURCE_ARN="arn:aws:rds:us-east-1:account:cluster:cluster-name"
# test_AWS_ROLE_ARN="arn:aws:iam::account:role/role-name"

# For Vercel deployment, set environment variables in Vercel dashboard
# vercel env add POSTGRES_URL

# Development Setup:
# 1. Get your AWS RDS credentials
# 2. Copy .env.example to .env.local
# 3. Replace YOUR_PASSWORD with actual password
# 4. Run: npm run db:init (to initialize schema)
# 5. Start dev server: npm run dev

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Authentication (Future)
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000

# AI Integration (Future)
# OPENAI_API_KEY=your-openai-key-here
